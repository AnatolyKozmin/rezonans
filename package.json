{
  "name": "rezonans",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "db:generate": "npm run db:generate -w @rezonans/api",
    "db:migrate": "npm run db:migrate -w @rezonans/api",
    "db:seed": "npm run db:seed -w @rezonans/api",
    "dev:api": "npm run dev -w @rezonans/api",
    "dev:bot": "npm run dev -w @rezonans/bot",
    "dev:web": "npm run dev -w @rezonans/web",
    "dev:site": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev": "concurrently -n api,bot,web -c blue,magenta,green \"npm run dev:api\" \"npm run dev:bot\" \"npm run dev:web\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
