# Скопируйте в apps/api/.env и apps/bot/.env (или используйте общий файл через symlink)

DATABASE_URL="file:./dev.db"
API_PORT=4000
API_PUBLIC_URL="http://localhost:4000"
CORS_ORIGIN="http://localhost:5173"

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# Админы (Telegram user id через запятую)
ADMIN_TELEGRAM_IDS=""

# Кампания: дата первого дня адвента (YYYY-MM-DD), часовой пояс
CAMPAIGN_START_DATE="2026-04-14"
TZ="Europe/Moscow"

# Напоминание: если не заходил N часов (например 24)
ADVENT_REMINDER_HOURS=24

# Защита admin API (страница /admin на сайте и загрузка файлов адвента)
ADMIN_API_KEY="change-me-in-production"
# В Docker: если в корневом .env для compose не задан ADMIN_API_KEY, в контейнере API подставляется dev-admin-key — вводите его в админке или задайте свой ключ в .env и перезапустите compose.

# Внутренние вызовы (бот → API, напоминания)
INTERNAL_API_KEY="change-internal"

# --- Docker Compose (корень репозитория): скопируйте в .env в корне репозитория ---
# В Docker compose база и uploads монтируются в ./apps/api/data и ./apps/api/uploads на хосте.
# В контейнере DATABASE_URL по умолчанию file:/app/apps/api/data/db.sqlite — не меняйте на ./dev.db, иначе БД окажется в слое образа и «пропадёт» после пересборки.
# WEB_PORT=8080   # по умолчанию в compose; если на сервере свободен только другой порт — смените (напр. 8081)
# API_PORT=4000
# CORS_ORIGIN=https://ваш-домен-или-http://IP   # должен совпадать с тем, как заказчик открывает сайт в браузере
# PUBLIC_WEB_URL=https://ваш-домен
# API_PUBLIC_URL=https://ваш-домен   # если отдаёте сайт и API с одного хоста за nginx
# TELEGRAM_BOT_TOKEN=  # для: docker compose --profile bot up
