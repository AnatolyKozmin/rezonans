# Dependencies & build
node_modules/
dist/

# Secrets & env (корень и apps/*)
.env
.env.*
!.env.example

# SQLite (локально и file:./data/…)
*.db
*.db-journal
apps/api/dev.db
apps/api/.vitest.sqlite
apps/api/.vitest.sqlite-journal
# Данные в ./apps/api/data (Docker bind-mount и локальный file:./data/db.sqlite) — не в git
apps/api/data/*
!apps/api/data/.gitkeep

# Загрузки API (структура — через .gitkeep)
apps/api/uploads/*
!apps/api/uploads/.gitkeep

# Локальные overrides Docker Compose
docker-compose.override.yml

# OS / IDE
.DS_Store
/certs

